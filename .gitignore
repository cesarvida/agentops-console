# Ignore build outputs
**/bin/
**/obj/
*.dll
*.pdb

# VS Code
.vscode/
.git-tracked-files.txt
commitmsg.txt

# Local environment secrets (never commit)
.env
.env.*
secrets.local.json
**/*.user.json
**/secrets.json

# Generated runtime outputs (re-created by the autopsy tool / validate-agent runs)
outputs/
AUTOPSY_REPORT.md
data/audit.log
data/evaluations/

# Local build/test artifacts
buildlog.txt
test_output.txt
**/TestResults/

# Workflow test artifacts
workflow-artifacts-*/

# User-generated rules (not version controlled)
data/rules/custom-*/

# Evaluation and governance reports (dynamically generated)
**/evaluation_*.json
**/governance_*.json

# Test and non-essential agent definitions
data/agent-definitions/test-*
data/agent-definitions/semantic-*
data/agent-definitions/bad-*

